<Window x:Class="BluetoothBatteryWidget.App.IconOverrideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="아이콘 수동 지정"
        Width="600"
        Height="420"
        MinWidth="520"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        Background="#101820">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Margin="0,0,0,10"
                   Foreground="#EAF4FF"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Text="기기 아이콘 수동 지정 (이미지 지정 시 이미지가 우선 적용)" />

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding IconItems}"
                  AutoGenerateColumns="False"
                  HeadersVisibility="Column"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  GridLinesVisibility="None"
                  Background="#1A2735"
                  Foreground="#EAF4FF"
                  BorderThickness="0"
                  RowBackground="#1A2735"
                  AlternatingRowBackground="#14202C"
                  AlternationCount="2">
            <DataGrid.Columns>
                <DataGridTextColumn Header="기기"
                                    Binding="{Binding DisplayName}"
                                    Width="2*" />
                <DataGridTextColumn Header="주소"
                                    Binding="{Binding Address}"
                                    Width="*" />
                <DataGridComboBoxColumn Header="아이콘"
                                        Width="*"
                                        SelectedValueBinding="{Binding SelectedIcon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        SelectedValuePath="Key"
                                        DisplayMemberPath="Label"
                                        ItemsSource="{Binding DataContext.IconChoices, RelativeSource={RelativeSource AncestorType=Window}}" />
                <DataGridTemplateColumn Header="사용자 이미지" Width="2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="160"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center"
                                           Text="{Binding CustomIconPath}"
                                           TextTrimming="CharacterEllipsis" />
                                <Button Width="56"
                                        Margin="0,0,6,0"
                                        Content="선택"
                                        Click="PickImageButton_Click" />
                                <Button Width="56"
                                        Content="초기화"
                                        Click="ClearImageButton_Click" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Width="90"
                    Margin="0,0,8,0"
                    Content="취소"
                    Click="CancelButton_Click" />
            <Button Width="90"
                    Content="저장"
                    IsDefault="True"
                    Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
