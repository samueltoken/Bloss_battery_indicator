<Window x:Class="BluetoothBatteryWidget.App.BatteryGuideTriggerCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Battery guide trigger"
        Width="1448"
        Height="1086"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        UseLayoutRounding="True"
        Focusable="True"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <DropShadowEffect x:Key="BlueprintGlow"
                          BlurRadius="8"
                          ShadowDepth="0"
                          Opacity="0.75"
                          Color="#FFFFFFFF" />
        <Style x:Key="BlueprintLine" TargetType="{x:Type Shape}">
            <Setter Property="Stroke" Value="#F2FFFFFF" />
            <Setter Property="StrokeThickness" Value="3" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="Effect" Value="{StaticResource BlueprintGlow}" />
        </Style>
        <Style x:Key="ThinBlueprintLine" TargetType="{x:Type Shape}" BasedOn="{StaticResource BlueprintLine}">
            <Setter Property="StrokeThickness" Value="1.4" />
            <Setter Property="Opacity" Value="0.58" />
        </Style>
        <Style x:Key="HotspotSurfaceStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="3" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        <Style x:Key="CaptureActionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="116" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Foreground" Value="#FAFFFFFF" />
            <Setter Property="Background" Value="#181D2730" />
            <Setter Property="BorderBrush" Value="#82FFFFFF" />
            <Setter Property="BorderThickness" Value="1.2" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#26344B62" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#CCFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CaptureTopTabControlStyle" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Height" Value="48" />
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"
                                    ClipToBounds="False" />
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <ItemsPresenter KeyboardNavigation.TabIndex="1" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CaptureTopTabItemStyle" TargetType="{x:Type TabItem}">
            <Setter Property="Width" Value="158" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Foreground" Value="#D9FFFFFF" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabChrome"
                                Background="#101A2430"
                                BorderBrush="#4DFFFFFF"
                                BorderThickness="1"
                                CornerRadius="10"
                                ClipToBounds="True"
                                RenderTransformOrigin="0.5,0.5"
                                SnapsToDevicePixels="True">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="TabPressScale"
                                                ScaleX="1"
                                                ScaleY="1" />
                            </Border.RenderTransform>
                            <Grid>
                                <Border x:Name="ConfiguredFillLayer"
                                        Background="#D9410A16"
                                        CornerRadius="10"
                                        Opacity="0" />
                                <Ellipse x:Name="WaterPulse"
                                         Width="132"
                                         Height="132"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Fill="#663C8DFF"
                                         Opacity="0"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform x:Name="WaterPulseScale"
                                                        ScaleX="0.24"
                                        ScaleY="0.24" />
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"
                                                  TextElement.FontSize="{TemplateBinding FontSize}"
                                                  TextElement.FontWeight="{TemplateBinding FontWeight}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="UIElement.PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="TabPressScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.965"
                                                         Duration="0:0:0.06" />
                                        <DoubleAnimation Storyboard.TargetName="TabPressScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.94"
                                                         Duration="0:0:0.06" />
                                        <DoubleAnimation Storyboard.TargetName="WaterPulse"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0.76"
                                                         To="0"
                                                         Duration="0:0:0.52">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="WaterPulseScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         From="0.18"
                                                         To="2.25"
                                                         Duration="0:0:0.52">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="WaterPulseScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         From="0.18"
                                                         To="2.25"
                                                         Duration="0:0:0.52">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="UIElement.PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="TabPressScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.22" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="TabPressScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.22" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Mouse.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="TabPressScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.14" />
                                        <DoubleAnimation Storyboard.TargetName="TabPressScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.14" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="#66295D9F" />
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="#C6A9D6FF" />
                                <Setter Property="Foreground" Value="#FFFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="#A52258C8" />
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="#FF75C7FF" />
                                <Setter Property="Foreground" Value="#FFFFFFFF" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="WaterPulse"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0.62"
                                                             To="0"
                                                             Duration="0:0:0.48">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="WaterPulseScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             From="0.22"
                                                             To="2.0"
                                                             Duration="0:0:0.48">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="WaterPulseScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             From="0.22"
                                                             To="2.0"
                                                             Duration="0:0:0.48">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                            <Trigger Property="Tag" Value="Configured">
                                <Setter TargetName="TabChrome" Property="Background" Value="#DC420914" />
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="#FFFF5F66" />
                                <Setter TargetName="ConfiguredFillLayer" Property="Opacity" Value="1" />
                                <Setter TargetName="WaterPulse" Property="Fill" Value="#99FF4054" />
                                <Setter Property="Foreground" Value="#FFFFF1F1" />
                            </Trigger>
                            <Trigger Property="Tag" Value="Steam">
                                <Setter TargetName="TabChrome" Property="Background" Value="#D70B4D30" />
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="#FF5DE3A6" />
                                <Setter TargetName="WaterPulse" Property="Fill" Value="#9A20D67A" />
                                <Setter Property="Foreground" Value="#FFF0FFF7" />
                            </Trigger>
                            <Trigger Property="Tag" Value="SteamConfigured">
                                <Setter TargetName="TabChrome" Property="Background" Value="#EA0B5D37" />
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="#FF78F0B8" />
                                <Setter TargetName="ConfiguredFillLayer" Property="Background" Value="#F00C6D40" />
                                <Setter TargetName="ConfiguredFillLayer" Property="Opacity" Value="1" />
                                <Setter TargetName="WaterPulse" Property="Fill" Value="#A820D67A" />
                                <Setter Property="Foreground" Value="#FFF0FFF7" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="Tag" Value="Configured" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabChrome" Property="Background" Value="#EA53101F" />
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="#FFFF8B8B" />
                                <Setter TargetName="ConfiguredFillLayer" Property="Background" Value="#EA5D1222" />
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="Tag" Value="Configured" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabChrome" Property="Background" Value="#F05A1021" />
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="#FFFF9898" />
                                <Setter TargetName="ConfiguredFillLayer" Property="Background" Value="#F0631426" />
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="Tag" Value="Steam" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabChrome" Property="Background" Value="#E20F6C43" />
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="#FF93FFD0" />
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="Tag" Value="Steam" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabChrome" Property="Background" Value="#F0117448" />
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="#FFA7FFD9" />
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="Tag" Value="SteamConfigured" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabChrome" Property="Background" Value="#F00F7749" />
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="#FFA8FFD8" />
                                <Setter TargetName="ConfiguredFillLayer" Property="Background" Value="#F5118050" />
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="Tag" Value="SteamConfigured" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabChrome" Property="Background" Value="#F4148555" />
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="#FFB8FFE0" />
                                <Setter TargetName="ConfiguredFillLayer" Property="Background" Value="#F8188E5C" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="WindowSurface"
            Margin="10"
            CornerRadius="14"
            BorderBrush="#4DFFFFFF"
            BorderThickness="1"
            ClipToBounds="True"
            RenderTransformOrigin="0.5,0.5"
            SizeChanged="WindowSurface_SizeChanged">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="WindowSurfaceScale"
                                ScaleX="1"
                                ScaleY="1" />
                <SkewTransform x:Name="WindowSurfaceSkew"
                               AngleX="0"
                               AngleY="0" />
                <TranslateTransform x:Name="WindowSurfaceTranslate"
                                    X="0"
                                    Y="0" />
            </TransformGroup>
        </Border.RenderTransform>
        <Border.Background>
            <SolidColorBrush x:Name="WindowSurfaceBackgroundBrush"
                             Color="#FF0F2A5C" />
        </Border.Background>
        <Grid x:Name="WindowSurfaceRoot"
              ClipToBounds="True">
            <Grid x:Name="CaptureThemeLayer"
                  Panel.ZIndex="0"
                  IsHitTestVisible="False"
                  ClipToBounds="True">
                <Border x:Name="CaptureThemeBaseTint"
                        Opacity="0.26">
                    <Border.Background>
                        <SolidColorBrush x:Name="CaptureThemeBaseTintBrush"
                                         Color="#FF2258C8" />
                    </Border.Background>
                </Border>
                <Canvas x:Name="CaptureThemeRippleCanvas"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        ClipToBounds="True">
                    <Ellipse x:Name="CaptureThemeRipple"
                             Width="1280"
                             Height="1280"
                             Opacity="0"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="CaptureThemeRippleScale"
                                            ScaleX="0.03"
                                            ScaleY="0.03" />
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </Canvas>
            </Grid>
            <Grid x:Name="CaptureContentLayer"
                  Margin="24,18,24,20"
                  Panel.ZIndex="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0,0,0,8"
                    Background="#01000000"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="HeaderDragArea_MouseLeftButtonDown">
                <TextBlock x:Name="PromptTextBlock"
                           HorizontalAlignment="Center"
                           Text="조합할 2개의 버튼을 눌러주세요"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#F7FFFFFF" />
            </Border>

            <TabControl x:Name="CaptureTabControl"
                        Grid.Row="1"
                        Margin="12,0,12,10"
                        Style="{StaticResource CaptureTopTabControlStyle}"
                        PreviewMouseLeftButtonDown="CaptureTabControl_PreviewMouseLeftButtonDown"
                        SelectionChanged="CaptureTabControl_SelectionChanged">
                <TabItem x:Name="CustomTabItem"
                         Header="사용자정의"
                         IsSelected="True"
                         Style="{StaticResource CaptureTopTabItemStyle}" />
                <TabItem x:Name="PlayStationTabItem"
                         Header="PS"
                         Style="{StaticResource CaptureTopTabItemStyle}" />
                <TabItem x:Name="SteamControllerTabItem"
                         Header="STEAMCON"
                         Style="{StaticResource CaptureTopTabItemStyle}" />
            </TabControl>

            <Viewbox Grid.Row="2"
                     Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center">
                <Canvas Width="1448"
                        Height="1086"
                        ClipToBounds="False">
                    <Image x:Name="OriginalBlueprintImage"
                           Canvas.Left="0"
                           Canvas.Top="0"
                           Width="1448"
                           Height="1086"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Opacity="0"
                           Visibility="Collapsed" />
                    <Image x:Name="BlueprintImageLineLayer"
                           Canvas.Left="0"
                           Canvas.Top="0"
                           Width="1448"
                           Height="1086"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           IsHitTestVisible="False"
                           Opacity="0.96"
                           Visibility="Collapsed" />
                    <Rectangle x:Name="BlueprintThemeWash"
                               Canvas.Left="0"
                               Canvas.Top="0"
                               Width="1448"
                               Height="1086"
                               IsHitTestVisible="False"
                               Opacity="0">
                        <Rectangle.Fill>
                            <SolidColorBrush x:Name="BlueprintThemeWashBrush"
                                             Color="#FF2258C8" />
                        </Rectangle.Fill>
                    </Rectangle>
                    <Canvas x:Name="VectorBlueprintLayer"
                             Width="1448"
                             Height="1086"
                             Visibility="Collapsed">
                    <Path Style="{StaticResource BlueprintLine}"
                          StrokeThickness="4"
                          Fill="#01000000"
                          Data="M94,780 C57,735 51,657 66,531 C84,375 132,222 255,205 C323,196 371,212 436,219 C505,227 967,227 1036,219 C1101,212 1149,196 1217,205 C1340,222 1388,375 1406,531 C1421,657 1415,735 1378,780 C1326,844 1247,834 1193,762 L1037,555 C1022,535 1002,525 978,525 L494,525 C470,525 450,535 435,555 L279,762 C225,834 146,844 94,780 Z" />
                    <Path Style="{StaticResource BlueprintLine}"
                          StrokeThickness="3"
                          Opacity="0.94"
                          Fill="Transparent"
                          Data="M255,205 C283,139 364,148 392,212 M1217,205 C1189,139 1108,148 1080,212" />
                    <Path Style="{StaticResource BlueprintLine}"
                          StrokeThickness="3"
                          Opacity="0.72"
                          Fill="Transparent"
                          Data="M87,768 C125,820 210,829 279,762 M1193,762 C1262,829 1347,820 1385,768" />

                    <Line Style="{StaticResource ThinBlueprintLine}" X1="736" Y1="246" X2="736" Y2="870" StrokeDashArray="5,9" />
                    <Line Style="{StaticResource ThinBlueprintLine}" X1="159" Y1="424" X2="1313" Y2="424" StrokeDashArray="5,9" />
                    <Line Style="{StaticResource ThinBlueprintLine}" X1="322" Y1="552" X2="322" Y2="861" />
                    <Line Style="{StaticResource ThinBlueprintLine}" X1="1290" Y1="552" X2="1290" Y2="861" />
                    <Line Style="{StaticResource ThinBlueprintLine}" X1="342" Y1="903" X2="1130" Y2="903" />
                    <Line Style="{StaticResource ThinBlueprintLine}" X1="206" Y1="903" X2="620" Y2="903" />
                    <Line Style="{StaticResource ThinBlueprintLine}" X1="852" Y1="903" X2="1266" Y2="903" />
                    <Line Style="{StaticResource ThinBlueprintLine}" X1="206" Y1="876" X2="206" Y2="930" />
                    <Line Style="{StaticResource ThinBlueprintLine}" X1="736" Y1="876" X2="736" Y2="930" />
                    <Line Style="{StaticResource ThinBlueprintLine}" X1="1266" Y1="876" X2="1266" Y2="930" />

                    <Line Style="{StaticResource ThinBlueprintLine}" X1="201" Y1="575" X2="201" Y2="673" StrokeDashArray="7,10" />
                    <Line Style="{StaticResource ThinBlueprintLine}" X1="165" Y1="624" X2="237" Y2="624" />
                    <Ellipse Canvas.Left="191" Canvas.Top="614" Width="20" Height="20" Stroke="#A8FFFFFF" StrokeThickness="1.4" />
                    <Line Style="{StaticResource ThinBlueprintLine}" X1="1270" Y1="575" X2="1270" Y2="673" StrokeDashArray="7,10" />
                    <Line Style="{StaticResource ThinBlueprintLine}" X1="1234" Y1="624" X2="1306" Y2="624" />
                    <Ellipse Canvas.Left="1260" Canvas.Top="614" Width="20" Height="20" Stroke="#A8FFFFFF" StrokeThickness="1.4" />
                    <Ellipse Canvas.Left="727" Canvas.Top="326" Width="18" Height="18" Stroke="#A8FFFFFF" StrokeThickness="1.4" />
                    <Ellipse Canvas.Left="727" Canvas.Top="788" Width="18" Height="18" Stroke="#A8FFFFFF" StrokeThickness="1.4" />

                    <Border Canvas.Left="95" Canvas.Top="83" Width="104" Height="58" CornerRadius="12" BorderBrush="#F2FFFFFF" BorderThickness="3" Effect="{StaticResource BlueprintGlow}">
                        <TextBlock Text="LT" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="32" Foreground="#F7FFFFFF" />
                    </Border>
                    <Line Style="{StaticResource BlueprintLine}" X1="199" Y1="112" X2="306" Y2="112" />
                    <Line Style="{StaticResource BlueprintLine}" X1="306" Y1="112" X2="376" Y2="195" />
                    <Border Canvas.Left="52" Canvas.Top="198" Width="104" Height="58" CornerRadius="12" BorderBrush="#F2FFFFFF" BorderThickness="3" Effect="{StaticResource BlueprintGlow}">
                        <TextBlock Text="LB" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="32" Foreground="#F7FFFFFF" />
                    </Border>
                    <Line Style="{StaticResource BlueprintLine}" X1="156" Y1="227" X2="246" Y2="227" />
                    <Line Style="{StaticResource BlueprintLine}" X1="246" Y1="227" X2="287" Y2="255" />
                    <Border Canvas.Left="1272" Canvas.Top="83" Width="104" Height="58" CornerRadius="12" BorderBrush="#F2FFFFFF" BorderThickness="3" Effect="{StaticResource BlueprintGlow}">
                        <TextBlock Text="RT" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="32" Foreground="#F7FFFFFF" />
                    </Border>
                    <Line Style="{StaticResource BlueprintLine}" X1="1272" Y1="112" X2="1166" Y2="112" />
                    <Line Style="{StaticResource BlueprintLine}" X1="1166" Y1="112" X2="1096" Y2="195" />
                    <Border Canvas.Left="1315" Canvas.Top="198" Width="104" Height="58" CornerRadius="12" BorderBrush="#F2FFFFFF" BorderThickness="3" Effect="{StaticResource BlueprintGlow}">
                        <TextBlock Text="RB" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="32" Foreground="#F7FFFFFF" />
                    </Border>
                    <Line Style="{StaticResource BlueprintLine}" X1="1315" Y1="227" X2="1225" Y2="227" />
