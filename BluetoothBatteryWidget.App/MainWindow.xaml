<Window x:Class="BluetoothBatteryWidget.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Width="540"
        Height="560"
        MinWidth="360"
        MinHeight="250"
        ResizeMode="CanResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        Closed="Window_Closed"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#10243C" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#314E6A" />
        <SolidColorBrush x:Key="BatteryTextBrush" Color="#132F4D" />
        <SolidColorBrush x:Key="CardTintBrush" Color="#C2FFFFFF" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#93FFFFFF" />
        <SolidColorBrush x:Key="WidgetBackgroundBrush" Color="#ECF5FF" />
        <SolidColorBrush x:Key="GlassSurfaceBrush" Color="#DDEAF3FF" />
        <SolidColorBrush x:Key="TrackBrush" Color="#7AB8C8D7" />
        <SolidColorBrush x:Key="IconBackBrush" Color="#E7F2F8FC" />
        <SolidColorBrush x:Key="IconBorderBrush" Color="#A3CBDDEE" />
        <SolidColorBrush x:Key="ActionButtonBackBrush" Color="#B5F5FAFF" />
        <SolidColorBrush x:Key="ActionButtonBorderBrush" Color="#9ECAE0EF" />
        <SolidColorBrush x:Key="SettingsTitleBrush" Color="#1D3E5B" />
        <SolidColorBrush x:Key="SettingsTextBrush" Color="#35617F" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <DataTemplate x:Key="ColorPresetComboTemplate">
            <Grid Width="124">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Width="30"
                      Height="18"
                      Margin="0,0,6,0"
                      VerticalAlignment="Center">
                    <Border CornerRadius="9"
                            Background="{Binding PreviewBrush}" />
                    <Border Width="14"
                            Height="14"
                            Margin="2"
                            HorizontalAlignment="Right"
                            CornerRadius="7"
                            Background="{Binding AccentBrush}" />
                </Grid>
                <Grid x:Name="ColorPresetMarqueeViewport"
                      Grid.Column="1"
                      Height="18"
                      VerticalAlignment="Center"
                      Background="Transparent"
                      ClipToBounds="True"
                      Loaded="ColorPresetMarqueeViewport_Loaded"
                      SizeChanged="ColorPresetMarqueeViewport_SizeChanged"
                      MouseEnter="ColorPresetMarqueeViewport_MouseEnter"
                      MouseLeave="ColorPresetMarqueeViewport_MouseLeave">
                    <Canvas Height="18"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False">
                        <TextBlock x:Name="ColorPresetMarqueeText"
                                   Canvas.Left="0"
                                   Canvas.Top="1"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#1C3550"
                                   Text="{Binding Label}"
                                   Loaded="ColorPresetMarqueeText_Loaded"
                                   SizeChanged="ColorPresetMarqueeText_SizeChanged">
                            <TextBlock.RenderTransform>
                                <TranslateTransform />
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Canvas>
                </Grid>
            </Grid>
        </DataTemplate>

        <Style x:Key="FlatListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{x:Null}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="#153A5C" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#45FFFFFF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#6BFFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GlassToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="26" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#98CFDBE9" />
            <Setter Property="BorderBrush" Value="#7D9CB4CC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="SwitchTrack"
                                    CornerRadius="13"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" />
                            <Border x:Name="SwitchThumb"
                                    Width="20"
                                    Height="20"
                                    Margin="3"
                                    HorizontalAlignment="Left"
                                    CornerRadius="10"
                                    Background="#F8FFFFFF"
                                    BorderBrush="#A7C1D7EB"
                                    BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="#46000000"
                                                      BlurRadius="6"
                                                      ShadowDepth="1"
                                                      Opacity="0.35" />
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#0057D9" />
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#003F9E" />
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="SwitchThumb" Property="BorderBrush" Value="#7CA6F1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassPanelActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#0B223D" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#EAF5FFFF" />
            <Setter Property="BorderBrush" Value="#7FA5C7E6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PanelButtonBorder"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PanelButtonBorder" Property="Background" Value="#F3FAFFFF" />
                                <Setter TargetName="PanelButtonBorder" Property="BorderBrush" Value="#6C97C2E0" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PanelButtonBorder" Property="Background" Value="#D5E9FAFF" />
                                <Setter TargetName="PanelButtonBorder" Property="BorderBrush" Value="#4D7AA7CC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BatteryGuideTriggerSelectButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource GlassPanelActionButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid ClipToBounds="True">
                            <Border x:Name="PanelButtonBorder"
                                    CornerRadius="12"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="8,6" />
                            <Border x:Name="ActiveGuideTriggerBorder"
                                    CornerRadius="12"
                                    BorderBrush="#9ED8F3FF"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="8,6"
                                    Opacity="0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#66B7E9FF"
                                                      BlurRadius="9"
                                                      ShadowDepth="0"
                                                      Opacity="0.55" />
                                </Border.Effect>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0"
                                                         EndPoint="1,0">
                                        <GradientStop x:Name="GuideActiveStopA"
                                                      Color="#DDF7FCFF"
                                                      Offset="-0.18" />
                                        <GradientStop x:Name="GuideActiveStopB"
                                                      Color="#BCE8F7FF"
                                                      Offset="0.45" />
                                        <GradientStop x:Name="GuideActiveStopC"
                                                      Color="#E7E5FFFF"
                                                      Offset="1.18" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <ContentPresenter Margin="8,6"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PanelButtonBorder" Property="Background" Value="#F3FAFFFF" />
                                <Setter TargetName="PanelButtonBorder" Property="BorderBrush" Value="#6C97C2E0" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PanelButtonBorder" Property="Background" Value="#D5E9FAFF" />
                                <Setter TargetName="PanelButtonBorder" Property="BorderBrush" Value="#4D7AA7CC" />
                            </Trigger>
                            <DataTrigger Binding="{Binding HasCustomBatteryGuideTrigger}" Value="True">
                                <Setter Property="Foreground" Value="#102A40" />
                                <Setter Property="BorderBrush" Value="#84C7E8FF" />
                                <Setter TargetName="PanelButtonBorder" Property="Opacity" Value="0" />
                                <Setter TargetName="ActiveGuideTriggerBorder" Property="Opacity" Value="1" />
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="BatteryGuideTriggerActivePulse">
                                        <Storyboard RepeatBehavior="Forever"
                                                    AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetName="GuideActiveStopA"
                                                             Storyboard.TargetProperty="Offset"
                                                             From="-0.18"
                                                             To="0.08"
                                                             Duration="0:0:2.4" />
                                            <DoubleAnimation Storyboard.TargetName="GuideActiveStopB"
                                                             Storyboard.TargetProperty="Offset"
                                                             From="0.45"
                                                             To="0.62"
                                                             Duration="0:0:2.4" />
                                            <DoubleAnimation Storyboard.TargetName="GuideActiveStopC"
                                                             Storyboard.TargetProperty="Offset"
                                                             From="1.18"
                                                             To="0.94"
                                                             Duration="0:0:2.4" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="BatteryGuideTriggerActivePulse" />
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BatteryGuideTriggerResetButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#10243C" />
            <Setter Property="Background" Value="#EAF5FFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}"
                              ClipToBounds="True"
                              RenderTransformOrigin="0.5,0.5">
                            <Grid x:Name="ResetCircleBody"
                                  RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <ScaleTransform x:Name="ResetCircleScale"
                                                    ScaleX="1"
                                                    ScaleY="1" />
                                </Grid.RenderTransform>
                                <Border x:Name="ResetWhiteCircle"
                                        CornerRadius="16"
                                        Background="#EAF5FFFF"
                                        BorderBrush="#BFD8E9F6"
                                        BorderThickness="1" />
                                <Image x:Name="ResetCircleImage"
                                       Source="pack://application:,,,/Assets/reset-button-blue.png"
                                       Stretch="Uniform"
                                       Opacity="0"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Grid>
                            <Ellipse x:Name="ResetInnerPulse"
                                     Width="22"
                                     Height="22"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Fill="#334A88FF"
                                     Opacity="0"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform x:Name="ResetInnerPulseScale"
                                                    ScaleX="0.65"
                                                    ScaleY="0.65" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="Button.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ResetInnerPulse"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0.22"
                                                         To="0"
                                                         Duration="0:0:0.34" />
                                        <DoubleAnimation Storyboard.TargetName="ResetInnerPulseScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         From="0.65"
                                                         To="1.05"
                                                         Duration="0:0:0.34"
                                                         DecelerationRatio="0.78" />
                                        <DoubleAnimation Storyboard.TargetName="ResetInnerPulseScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         From="0.65"
                                                         To="1.05"
                                                         Duration="0:0:0.34"
                                                         DecelerationRatio="0.78" />
                                        <DoubleAnimation Storyboard.TargetName="ResetCircleScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         From="0.9"
                                                         To="1"
                                                         Duration="0:0:0.32"
                                                         DecelerationRatio="0.7" />
                                        <DoubleAnimation Storyboard.TargetName="ResetCircleScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         From="0.9"
                                                         To="1"
                                                         Duration="0:0:0.32"
                                                         DecelerationRatio="0.7" />
                                        </Storyboard>
                                    </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ResetWhiteCircle" Property="Background" Value="#F5FBFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ResetWhiteCircle" Property="Background" Value="#DCECF8FF" />
                            </Trigger>
                            <DataTrigger Binding="{Binding HasCustomBatteryGuideTrigger}" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFFFF" />
                                <Setter TargetName="ResetWhiteCircle" Property="Opacity" Value="0" />
                                <Setter TargetName="ResetCircleImage" Property="Opacity" Value="1" />
                                <Setter TargetName="ResetInnerPulse" Property="Fill" Value="#66FFFFFF" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UiScaleSliderTrackButtonStyle" TargetType="RepeatButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UiScaleSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="44" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="44"
                              Margin="2,0"
                              ClipToBounds="False">
                            <Border Height="11"
                                    Margin="7,0"
                                    VerticalAlignment="Center"
                                    CornerRadius="6"
                                    Background="#EDF4FAFF"
                                    BorderBrush="#A8C4D8EA"
                                    BorderThickness="1" />
                            <Border Height="5"
                                    Margin="15,0"
                                    VerticalAlignment="Center"
                                    CornerRadius="3"
                                    Background="#C8D4E4F2" />
                            <Track x:Name="PART_Track"
                                   Height="34"
                                   Margin="15,0"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                  Style="{StaticResource UiScaleSliderTrackButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                  Style="{StaticResource UiScaleSliderTrackButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="26"
                                           Height="26"
                                           Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid Width="26"
                                                      Height="26"
                                                      ClipToBounds="False">
                                                    <Ellipse Fill="#FFFFFFFF"
                                                             Stroke="#FF2F7DF0"
                                                             StrokeThickness="2">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect Color="#4D1D4D84"
                                                                              BlurRadius="8"
                                                                              ShadowDepth="1"
                                                                              Opacity="0.28" />
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                    <Ellipse Width="7"
                                                             Height="7"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             Fill="#FF2F7DF0" />
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsMenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="Foreground" Value="#202B36" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#78F7FBFF" />
            <Setter Property="BorderBrush" Value="#00FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MenuButtonBorder"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="10,0">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MenuButtonBorder" Property="Background" Value="#ECF4F9FF" />
                                <Setter TargetName="MenuButtonBorder" Property="BorderBrush" Value="#9CC7DAEC" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MenuButtonBorder" Property="Background" Value="#DDECF7FF" />
                                <Setter TargetName="MenuButtonBorder" Property="BorderBrush" Value="#7CB2CEE8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorElementButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource GlassPanelActionButtonStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="MinHeight" Value="37" />
            <Setter Property="Foreground" Value="#10243C" />
            <Setter Property="Background" Value="#ECF7FBFF" />
            <Setter Property="BorderBrush" Value="#88BDD6E8" />
        </Style>

        <Style x:Key="ColorQuickSwatchButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SwatchButtonChrome"
                                CornerRadius="9"
                                BorderThickness="1"
                                BorderBrush="#88A7BED2"
                                Background="#8EF6FBFF"
                                Padding="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwatchButtonChrome" Property="BorderBrush" Value="#5F8DC2E8" />
                                <Setter TargetName="SwatchButtonChrome" Property="Background" Value="#D8F8FCFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SwatchButtonChrome" Property="BorderBrush" Value="#416F9EC7" />
                                <Setter TargetName="SwatchButtonChrome" Property="Background" Value="#BDDFF2FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerExitButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource GlassPanelActionButtonStyle}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#7B1028" />
            <Setter Property="BorderBrush" Value="#5D0B1D" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PanelButtonBorder"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="8,6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PanelButtonBorder" Property="Background" Value="#8E1632" />
                                <Setter TargetName="PanelButtonBorder" Property="BorderBrush" Value="#6A1025" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PanelButtonBorder" Property="Background" Value="#5E0D1F" />
                                <Setter TargetName="PanelButtonBorder" Property="BorderBrush" Value="#450916" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InlineNameActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource GlassPanelActionButtonStyle}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="MinWidth" Value="62" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style x:Key="GlassPresetComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#1D3E5B" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="ColorPresetComboBoxItem_PreviewMouseLeftButtonDown" />
            <EventSetter Event="PreviewMouseLeftButtonUp" Handler="ColorPresetComboBoxItem_PreviewMouseLeftButtonUp" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Margin="2"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="8"
                                BorderThickness="1"
                                BorderBrush="Transparent"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EAF5FFFF" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#8FB9D7EF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#D9EDF9FF" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#86B9CFE4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboTransparentToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassPresetComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#1D3E5B" />
            <Setter Property="Background" Value="#E8F3FBFF" />
            <Setter Property="BorderBrush" Value="#8FB9D7EF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Padding" Value="8,4,2,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    CornerRadius="10"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" />

                            <Grid Margin="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="26" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding ItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  IsHitTestVisible="False" />

                                <TextBlock Grid.Column="1"
                                           Text="⌄"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"
                                           IsHitTestVisible="False" />

                                <ToggleButton Grid.ColumnSpan="2"
                                              Focusable="False"
                                              Style="{StaticResource ComboTransparentToggleButtonStyle}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" />
                            </Grid>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Margin="0,6,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        CornerRadius="12"
                                        BorderThickness="1"
                                        BorderBrush="#86AFCDEA"
                                        Background="#ECF7FFFF">
                                    <ScrollViewer MaxHeight="240"
                                                  Margin="4"
                                                  SnapsToDevicePixels="True"
                                                  VerticalScrollBarVisibility="Hidden"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  CanContentScroll="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#4E89B8E2" />
                                <Setter TargetName="ComboBorder" Property="Background" Value="#F0F9FFFF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="Background" Value="#F2FAFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassScrollingComboBoxStyle"
               TargetType="ComboBox"
               BasedOn="{StaticResource GlassPresetComboBoxStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    CornerRadius="10"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" />

                            <Grid Margin="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="26" />
                                </Grid.ColumnDefinitions>

                                <Grid x:Name="ComboMarqueeViewport"
                                      Margin="{TemplateBinding Padding}"
                                      Height="18"
                                      VerticalAlignment="Center"
                                      ClipToBounds="True"
                                      IsHitTestVisible="False"
                                      Loaded="ColorPresetMarqueeViewport_Loaded"
                                      SizeChanged="ColorPresetMarqueeViewport_SizeChanged">
                                    <Canvas Height="18"
                                            VerticalAlignment="Center"
                                            IsHitTestVisible="False">
                                        <TextBlock x:Name="ComboMarqueeText"
                                                   Canvas.Left="0"
                                                   Canvas.Top="1"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                                   Loaded="ColorPresetMarqueeText_Loaded"
                                                   SizeChanged="ColorPresetMarqueeText_SizeChanged">
                                            <TextBlock.RenderTransform>
                                                <TranslateTransform />
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                    </Canvas>
                                </Grid>

                                <TextBlock Grid.Column="1"
                                           Text="⌄"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"
                                           IsHitTestVisible="False" />

                                <ToggleButton Grid.ColumnSpan="2"
                                              Focusable="False"
                                              Style="{StaticResource ComboTransparentToggleButtonStyle}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" />
                            </Grid>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Margin="0,6,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        CornerRadius="12"
                                        BorderThickness="1"
                                        BorderBrush="#86AFCDEA"
                                        Background="#ECF7FFFF">
                                    <ScrollViewer MaxHeight="240"
                                                  Margin="4"
                                                  SnapsToDevicePixels="True"
                                                  VerticalScrollBarVisibility="Hidden"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  CanContentScroll="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#4E89B8E2" />
                                <Setter TargetName="ComboBorder" Property="Background" Value="#F0F9FFFF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="Background" Value="#F2FAFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="GlassWaveStoryboard"
                    RepeatBehavior="Forever"
                    AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="GsMid"
                             Storyboard.TargetProperty="Offset"
                             From="0.35"
                             To="0.55"
                             Duration="0:0:4" />
            <DoubleAnimation Storyboard.TargetName="GsBottom"
                             Storyboard.TargetProperty="Offset"
                             From="0.92"
                             To="1.08"
                             Duration="0:0:4" />
        </Storyboard>

        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="28" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="BorderBrush" Value="#A0FFFFFF" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#80FFFFFF"
                                      BlurRadius="24"
                                      ShadowDepth="0"
                                      Opacity="0.75" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLiteVisualMode}" Value="True">
                    <Setter Property="BorderBrush" Value="#66FFFFFF" />
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#52FFFFFF"
                                              BlurRadius="12"
                                              ShadowDepth="0"
                                              Opacity="0.35" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border x:Name="GlassCard"
                Margin="6"
                Padding="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Style="{StaticResource GlassCardStyle}"
                SnapsToDevicePixels="True">
            <Border.RenderTransform>
                <ScaleTransform x:Name="UiScaleTransform"
                                ScaleX="1"
                                ScaleY="1" />
            </Border.RenderTransform>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop x:Name="GsTop" Color="#1AFFFFFF" Offset="0.0" />
                    <GradientStop x:Name="GsMid" Color="#33FFFFFF" Offset="0.4" />
                    <GradientStop x:Name="GsBottom" Color="#66FFFFFF" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid x:Name="GlassCardContent">
                <Grid x:Name="GlassTextureLayer"
                      Panel.ZIndex="0"
                      ClipToBounds="True"
                      IsHitTestVisible="False"
                      Opacity="0.88">
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop x:Name="GlassSheenTop" Offset="0" Color="#18FFFFFF" />
                                <GradientStop x:Name="GlassSheenMiddle" Offset="0.52" Color="#08FFFFFF" />
                                <GradientStop x:Name="GlassSheenBottom" Offset="1" Color="#24CFEAFF" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Rectangle Opacity="0.55">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="1,0" EndPoint="0,1">
                                <GradientStop x:Name="GlassDepthTop" Offset="0" Color="#16FFFFFF" />
                                <GradientStop x:Name="GlassDepthBottom" Offset="1" Color="#1E9BC4DF" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </Grid>

                <Grid Panel.ZIndex="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="8"
                            CornerRadius="18"
                            BorderThickness="1"
                            BorderBrush="#89FFFFFF">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop x:Name="ListTopStop" Offset="0" Color="#A7FFFFFF" />
                                <GradientStop x:Name="ListBottomStop" Offset="1" Color="#88ECF5FF" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <ListBox x:Name="DeviceListBox"
                                 ItemsSource="{Binding Devices}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 ItemContainerStyle="{StaticResource FlatListBoxItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="12,10"
                                            CornerRadius="18"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource CardTintBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsCharging}" Value="True" />
                                                            <Condition Binding="{Binding DataContext.UseCustomColors, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#FFFFF9DE" Offset="0" />
                                                                    <GradientStop Color="#FFFFE8A8" Offset="0.55" />
                                                                    <GradientStop Color="#FFFFF4C8" Offset="1" />
                                                                </LinearGradientBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter Property="BorderBrush" Value="#FFFFCF5A" />
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsChargeComplete}" Value="True" />
                                                            <Condition Binding="{Binding DataContext.UseCustomColors, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#FFEAF7FF" Offset="0" />
                                                                    <GradientStop Color="#FFC9E9FF" Offset="0.55" />
                                                                    <GradientStop Color="#FFE4F4FF" Offset="1" />
                                                                </LinearGradientBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter Property="BorderBrush" Value="#FF8FC9F0" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Grid>
                                                <Border x:Name="DeviceIconHitArea"
                                                        Width="48"
                                                        Height="48"
                                                        CornerRadius="24"
                                                        BorderThickness="1"
                                                        Cursor="Hand"
                                                        MouseLeftButtonDown="DeviceIconBorder_MouseLeftButtonDown">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource IconBackBrush}" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource IconBorderBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasCustomIconImage}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource CardTintBrush}" />
                                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid ClipToBounds="True">
                                                        <Grid.Clip>
                                                            <EllipseGeometry Center="24,24" RadiusX="23" RadiusY="23" />
                                                        </Grid.Clip>
                                                        <Image Source="{Binding CustomIconImagePath}"
                                                               Stretch="UniformToFill"
                                                               RenderOptions.BitmapScalingMode="HighQuality">
                                                            <Image.OpacityMask>
                                                                <RadialGradientBrush Center="0.5,0.5"
                                                                                     GradientOrigin="0.5,0.5"
                                                                                     RadiusX="0.62"
                                                                                     RadiusY="0.62">
                                                                    <GradientStop Color="#FFFFFFFF" Offset="0.62" />
                                                                    <GradientStop Color="#C8FFFFFF" Offset="0.82" />
                                                                    <GradientStop Color="#00FFFFFF" Offset="1" />
                                                                </RadialGradientBrush>
                                                            </Image.OpacityMask>
                                                            <Image.Style>
                                                                <Style TargetType="Image">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasCustomIconImage}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Image.Style>
                                                        </Image>

                                                        <TextBlock HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="20"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   Foreground="#20537A"
                                                                   Text="{Binding IconKey, Converter={StaticResource IconGlyphConverter}}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasCustomIconImage}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>

                                                <Popup PlacementTarget="{Binding ElementName=DeviceIconHitArea}"
                                                       Placement="Bottom"
                                                       AllowsTransparency="True"
                                                       PopupAnimation="Fade"
                                                       StaysOpen="True"
                                                       IsOpen="{Binding IsIconEditing, Mode=TwoWay}">
                                                    <Popup.DataContext>
                                                        <Binding ElementName="DeviceIconHitArea" Path="DataContext" />
                                                    </Popup.DataContext>
                                                    <Border Margin="0,8,0,0"
                                                            Padding="9"
                                                            MinWidth="142"
                                                            CornerRadius="12"
                                                            BorderThickness="1"
                                                            Background="#F3F8FFFF"
                                                            BorderBrush="#8AB0CEE6">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="#56000000"
                                                                              BlurRadius="14"
                                                                              ShadowDepth="2"
                                                                              Opacity="0.26" />
                                                        </Border.Effect>
                                                        <StackPanel>
                                                            <Button Content="{Binding DataContext.TextIconChange, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    Style="{StaticResource InlineNameActionButtonStyle}"
                                                                    Click="IconPickInlineButton_Click" />
                                                            <Button Content="{Binding DataContext.TextRestoreDefault, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    Margin="0,6,0,0"
                                                                    Style="{StaticResource InlineNameActionButtonStyle}"
                                                                    Click="IconResetInlineButton_Click" />
                                                            <Button Content="{Binding DataContext.TextInlineCancel, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    Margin="0,6,0,0"
                                                                    Style="{StaticResource InlineNameActionButtonStyle}"
                                                                    Click="IconCancelInlineButton_Click" />
                                                        </StackPanel>
                                                    </Border>
                                                </Popup>
                                            </Grid>

                                            <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                                                <TextBlock x:Name="DisplayNameTextBlock"
                                                           Text="{Binding DisplayName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           FontSize="17"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           Cursor="Hand"
                                                           MouseLeftButtonDown="DisplayNameTextBlock_MouseLeftButtonDown">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <StackPanel x:Name="RenameEditorPanel"
                                                            Margin="0,0,0,2"
                                                            Visibility="{Binding IsRenaming, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBox x:Name="NameEditorTextBox"
                                                             Text="{Binding EditableName, UpdateSourceTrigger=PropertyChanged}"
                                                             FontSize="13"
                                                             Padding="6,3"
                                                             Margin="0,0,0,5"
                                                             KeyDown="NameEditorTextBox_KeyDown"
                                                             IsVisibleChanged="NameEditorTextBox_IsVisibleChanged" />

                                                    <WrapPanel Orientation="Horizontal"
                                                               MaxWidth="{Binding ActualWidth, ElementName=RenameEditorPanel}">
                                                        <Button Content="{Binding DataContext.TextInlineSave, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                Style="{StaticResource InlineNameActionButtonStyle}"
                                                                Margin="0,0,6,6"
                                                                Click="NameSaveButton_Click" />
                                                        <Button Content="{Binding DataContext.TextInlineCancel, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                Style="{StaticResource InlineNameActionButtonStyle}"
                                                                Margin="0,0,6,6"
                                                                Click="NameCancelButton_Click" />
                                                        <Button Content="{Binding DataContext.TextRestoreDefault, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                Margin="0,0,0,6"
                                                                Click="NameResetButton_Click">
                                                            <Button.Style>
                                                                <Style TargetType="Button"
                                                                       BasedOn="{StaticResource InlineNameActionButtonStyle}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasCustomName}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </WrapPanel>
                                                </StackPanel>

                                                <TextBlock Text="{Binding Address}"
                                                           Margin="0,2,0,0"
                                                           FontSize="14"
                                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Top"
                                                        HorizontalAlignment="Right">
                                                <TextBlock FontSize="28"
                                                           FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource BatteryTextBrush}" />
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource BatteryPercentTextConverter}">
                                                            <Binding Path="BatteryPercent" />
                                                            <Binding Path="IsStale" />
                                                            <Binding Path="IsConnected" />
                                                            <Binding Path="IsBatteryConnecting" />
                                                            <Binding Path="IsCharging" />
                                                            <Binding Path="DataContext.Language" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <TextBlock Text="&#xE945;"
                                                           Margin="6,2,0,0"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding IsCharging, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#B7791F" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsChargeComplete}" Value="True">
                                                                    <Setter Property="Foreground" Value="#1D5F8B" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>

                                            <Popup PlacementTarget="{Binding ElementName=DisplayNameTextBlock}"
                                                   Placement="Top"
                                                   AllowsTransparency="True"
                                                   PopupAnimation="Fade"
                                                   StaysOpen="True"
                                                   IsHitTestVisible="False"
                                                   IsOpen="{Binding IsBatteryGuideVisible, Mode=OneWay}">
                                                <Popup.DataContext>
                                                    <Binding ElementName="DisplayNameTextBlock" Path="DataContext" />
                                                </Popup.DataContext>
                                                <Border Margin="0,0,0,10"
                                                        Padding="18,12"
                                                        MinWidth="250"
                                                        MaxWidth="390"
                                                        CornerRadius="16"
                                                        BorderThickness="1.4"
                                                        Background="#FBFFF9E8"
                                                        BorderBrush="#E7C553">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#56000000"
                                                                          BlurRadius="22"
                                                                          ShadowDepth="3"
                                                                          Opacity="0.30" />
                                                    </Border.Effect>
                                                    <TextBlock Text="{Binding BatteryGuideMessage}"
