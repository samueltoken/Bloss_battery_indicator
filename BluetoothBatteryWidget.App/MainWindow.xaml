                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="154" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,10,0">
                            <Button x:Name="PrimaryTextColorButton"
                                    Tag="PrimaryText"
                                    Style="{StaticResource ColorElementButtonStyle}"
                                    Click="ColorElementButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="PrimaryTextSwatch" Width="20" Height="20" HorizontalAlignment="Left" CornerRadius="10" Background="{DynamicResource PrimaryTextBrush}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding TextColorTargetPrimaryText}" />
                                </Grid>
                            </Button>
                            <Button x:Name="SecondaryTextColorButton"
                                    Tag="SecondaryText"
                                    Style="{StaticResource ColorElementButtonStyle}"
                                    Click="ColorElementButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="SecondaryTextSwatch" Width="20" Height="20" HorizontalAlignment="Left" CornerRadius="10" Background="{DynamicResource SecondaryTextBrush}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding TextColorTargetSecondaryText}" />
                                </Grid>
                            </Button>
                            <Button x:Name="BatteryTextColorButton"
                                    Tag="BatteryText"
                                    Style="{StaticResource ColorElementButtonStyle}"
                                    Click="ColorElementButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="BatteryTextSwatch" Width="20" Height="20" HorizontalAlignment="Left" CornerRadius="10" Background="{DynamicResource BatteryTextBrush}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding TextColorTargetBatteryText}" />
                                </Grid>
                            </Button>
                            <Button x:Name="WidgetBackgroundColorButton"
                                    Tag="WidgetBackground"
                                    Style="{StaticResource ColorElementButtonStyle}"
                                    Click="ColorElementButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="WidgetBackgroundSwatch" Width="20" Height="20" HorizontalAlignment="Left" CornerRadius="10" Background="{DynamicResource WidgetBackgroundBrush}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding TextColorTargetWidgetBackground}" />
                                </Grid>
                            </Button>
                            <Button x:Name="GlassSurfaceColorButton"
                                    Tag="GlassSurface"
                                    Style="{StaticResource ColorElementButtonStyle}"
                                    Click="ColorElementButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="GlassSurfaceSwatch" Width="20" Height="20" HorizontalAlignment="Left" CornerRadius="10" Background="{DynamicResource GlassSurfaceBrush}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding TextColorTargetGlassSurface}" />
                                </Grid>
                            </Button>
                            <Button x:Name="CardTintColorButton"
                                    Tag="CardTint"
                                    Style="{StaticResource ColorElementButtonStyle}"
                                    Click="ColorElementButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="CardTintSwatch" Width="20" Height="20" HorizontalAlignment="Left" CornerRadius="10" Background="{DynamicResource CardTintBrush}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding TextColorTargetCardTint}" />
                                </Grid>
                            </Button>
                            <Button x:Name="CardBorderColorButton"
                                    Tag="CardBorder"
                                    Style="{StaticResource ColorElementButtonStyle}"
                                    Click="ColorElementButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="CardBorderSwatch" Width="20" Height="20" HorizontalAlignment="Left" CornerRadius="10" Background="{DynamicResource CardBorderBrush}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding TextColorTargetCardBorder}" />
                                </Grid>
                            </Button>
                            <Button x:Name="TrackColorButton"
                                    Tag="Track"
                                    Style="{StaticResource ColorElementButtonStyle}"
                                    Click="ColorElementButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="TrackSwatch" Width="20" Height="20" HorizontalAlignment="Left" CornerRadius="10" Background="{DynamicResource TrackBrush}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding TextColorTargetTrack}" />
                                </Grid>
                            </Button>
                            <Button x:Name="PanelColorButton"
                                    Tag="Panel"
                                    Style="{StaticResource ColorElementButtonStyle}"
                                    Click="ColorElementButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="PanelSwatch" Width="20" Height="20" HorizontalAlignment="Left" CornerRadius="10" Background="{DynamicResource ActionButtonBackBrush}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding TextColorTargetPanel}" />
                                </Grid>
                            </Button>
                            <Button x:Name="SettingsTextColorButton"
                                    Tag="SettingsText"
                                    Style="{StaticResource ColorElementButtonStyle}"
                                    Click="ColorElementButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="SettingsTextSwatch" Width="20" Height="20" HorizontalAlignment="Left" CornerRadius="10" Background="{DynamicResource SettingsTextBrush}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding TextColorTargetSettingsText}" />
                                </Grid>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <Border x:Name="PaletteSurface"
                                    Height="196"
                                    CornerRadius="16"
                                    ClipToBounds="True"
                                    MouseLeftButtonDown="PaletteSurface_MouseLeftButtonDown"
                                    MouseMove="PaletteSurface_MouseMove"
                                    MouseLeftButtonUp="PaletteSurface_MouseLeftButtonUp"
                                    MouseLeave="PaletteSurface_MouseLeave">
                                <Grid Background="Transparent">
                                    <Rectangle>
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FFFF5656" Offset="0.00" />
                                                <GradientStop Color="#FFFFD84D" Offset="0.16" />
                                                <GradientStop Color="#FF6EE7A7" Offset="0.32" />
                                                <GradientStop Color="#FF44D7E8" Offset="0.50" />
                                                <GradientStop Color="#FF6B8CFF" Offset="0.68" />
                                                <GradientStop Color="#FFC977F2" Offset="0.84" />
                                                <GradientStop Color="#FFFF6BAA" Offset="1.00" />
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <Rectangle>
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#DDFFFFFF" Offset="0" />
                                                <GradientStop Color="#00FFFFFF" Offset="0.45" />
                                                <GradientStop Color="#26000000" Offset="0.78" />
                                                <GradientStop Color="#F2000000" Offset="1" />
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <Ellipse x:Name="PaletteCursor"
                                             Width="16"
                                             Height="16"
                                             Stroke="#F8FFFFFF"
                                             StrokeThickness="2"
                                             Fill="#33000000"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Top"
                                             Margin="0" />
                                </Grid>
                            </Border>

                            <StackPanel x:Name="ColorQuickSwatchPanel"
                                        Margin="0,10,0,0"
                                        Orientation="Horizontal">
                                <Button Width="30"
                                        Height="24"
                                        Margin="0,0,6,0"
                                        Padding="0"
                                        Style="{StaticResource ColorQuickSwatchButtonStyle}"
                                        Background="Transparent"
                                        BorderBrush="#88A7BED2"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Focusable="False"
                                        Tag="#000000"
                                        Click="ColorQuickSwatchButton_Click">
                                    <Border Width="20" Height="14" CornerRadius="5" Background="#FF000000" />
                                </Button>
                                <Button Width="30"
                                        Height="24"
                                        Margin="0,0,6,0"
                                        Padding="0"
                                        Style="{StaticResource ColorQuickSwatchButtonStyle}"
                                        Background="Transparent"
                                        BorderBrush="#88A7BED2"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Focusable="False"
                                        Tag="#1E1E1E"
                                        Click="ColorQuickSwatchButton_Click">
                                    <Border Width="20" Height="14" CornerRadius="5" Background="#FF1E1E1E" />
                                </Button>
                                <Button Width="30"
                                        Height="24"
                                        Margin="0,0,6,0"
                                        Padding="0"
                                        Style="{StaticResource ColorQuickSwatchButtonStyle}"
                                        Background="Transparent"
                                        BorderBrush="#88A7BED2"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Focusable="False"
                                        Tag="#6B7280"
                                        Click="ColorQuickSwatchButton_Click">
                                    <Border Width="20" Height="14" CornerRadius="5" Background="#FF6B7280" />
                                </Button>
                                <Button Width="30"
                                        Height="24"
                                        Margin="0,0,6,0"
                                        Padding="0"
                                        Style="{StaticResource ColorQuickSwatchButtonStyle}"
                                        Background="Transparent"
                                        BorderBrush="#88A7BED2"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Focusable="False"
                                        Tag="#FFFFFF"
                                        Click="ColorQuickSwatchButton_Click">
                                    <Border Width="20" Height="14" CornerRadius="5" BorderBrush="#66869AAF" BorderThickness="1" Background="#FFFFFFFF" />
                                </Button>
                                <Button Width="30"
                                        Height="24"
                                        Margin="0,0,6,0"
                                        Padding="0"
                                        Style="{StaticResource ColorQuickSwatchButtonStyle}"
                                        Background="Transparent"
                                        BorderBrush="#88A7BED2"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Focusable="False"
                                        Tag="#F43F5E"
                                        Click="ColorQuickSwatchButton_Click">
                                    <Border Width="20" Height="14" CornerRadius="5" Background="#FFF43F5E" />
                                </Button>
                                <Button Width="30"
                                        Height="24"
                                        Padding="0"
                                        Style="{StaticResource ColorQuickSwatchButtonStyle}"
                                        Background="Transparent"
                                        BorderBrush="#88A7BED2"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Focusable="False"
                                        Tag="#2563EB"
                                        Click="ColorQuickSwatchButton_Click">
                                    <Border Width="20" Height="14" CornerRadius="5" Background="#FF2563EB" />
                                </Button>
                            </StackPanel>

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="SelectedColorPreviewBorder"
                                        Width="38"
                                        Height="30"
                                        CornerRadius="10"
                                        BorderThickness="1"
                                        BorderBrush="#88A7BED2"
                                        Background="{DynamicResource PrimaryTextBrush}" />
                                <TextBlock x:Name="SelectedColorHexText"
                                           Grid.Column="1"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SettingsTitleBrush}"
                                           Text="#10243C" />
                            </Grid>

                            <Button Margin="0,10,0,0"
                                    Style="{StaticResource GlassPanelActionButtonStyle}"
                                    Click="ResetCustomColorsButton_Click"
                                    Content="{Binding TextColorReset}" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2"
                            Margin="0,12,0,0"
                            Padding="10"
                            CornerRadius="14"
                            BorderThickness="1"
                            BorderBrush="#92C4DAEC"
                            Background="#C8F4FAFF">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0"
                                       Grid.ColumnSpan="3"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SettingsTitleBrush}"
                                       Text="{Binding TextSettingsTextStyle}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="0,9,10,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource SettingsTextBrush}"
                                       Text="{Binding TextSettingsTextFontSize}" />
                            <Border x:Name="SettingsTextFontSizeValueBadge"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Width="42"
                                    Height="22"
                                    Margin="0,9,0,0"
                                    HorizontalAlignment="Center"
                                    CornerRadius="9"
                                    BorderThickness="1"
                                    BorderBrush="#8CB9D0E4"
                                    Background="#B8FFFFFF">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SettingsTitleBrush}"
                                           TextAlignment="Center"
                                           Text="{Binding SettingsTextFontSize, StringFormat={}{0:0}}" />
                            </Border>
                            <Slider x:Name="SettingsTextFontSizeSlider"
                                    Grid.Row="2"
                                    Grid.ColumnSpan="3"
                                    Margin="0,0,0,4"
                                    Style="{StaticResource UiScaleSliderStyle}"
                                    Minimum="11"
                                    Maximum="18"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    SmallChange="1"
                                    LargeChange="1"
                                    Value="{Binding SettingsTextFontSize, Mode=OneWay}"
                                    ValueChanged="SettingsTextFontSizeSlider_ValueChanged" />

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource SettingsTextBrush}"
                                       Text="{Binding TextSettingsTextBold}" />
                            <StackPanel Grid.Row="3"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="2"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <ToggleButton x:Name="SettingsTextBoldToggle"
                                              Width="50"
                                              Height="26"
                                              Margin="0,0,8,0"
                                              Style="{StaticResource GlassToggleSwitchStyle}"
                                              IsChecked="{Binding SettingsTextBold, Mode=OneWay}"
                                              Checked="SettingsTextBoldToggle_Checked"
                                              Unchecked="SettingsTextBoldToggle_Unchecked" />
                                <Button x:Name="ResetSettingsTextStyleButton"
                                        MinWidth="128"
                                        Height="36"
                                        Style="{StaticResource GlassPanelActionButtonStyle}"
                                        Click="ResetSettingsTextStyleButton_Click"
                                        Content="{Binding TextSettingsTextReset}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="3"
                               Margin="0,10,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource SettingsTextBrush}"
                               Text="{Binding TextColorDragHint}" />
                </Grid>
            </Border>
        </Popup>
    </Grid>
</Window>
