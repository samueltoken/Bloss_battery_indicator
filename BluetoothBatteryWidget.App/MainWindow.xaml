<Window x:Class="BluetoothBatteryWidget.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Width="540"
        Height="560"
        MinWidth="360"
        MinHeight="250"
        ResizeMode="CanResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        Closed="Window_Closed"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#10243C" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#314E6A" />
        <SolidColorBrush x:Key="BatteryTextBrush" Color="#132F4D" />
        <SolidColorBrush x:Key="CardTintBrush" Color="#C2FFFFFF" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#93FFFFFF" />
        <SolidColorBrush x:Key="TrackBrush" Color="#7AB8C8D7" />
        <SolidColorBrush x:Key="IconBackBrush" Color="#E7F2F8FC" />
        <SolidColorBrush x:Key="IconBorderBrush" Color="#A3CBDDEE" />
        <SolidColorBrush x:Key="ActionButtonBackBrush" Color="#B5F5FAFF" />
        <SolidColorBrush x:Key="ActionButtonBorderBrush" Color="#9ECAE0EF" />
        <SolidColorBrush x:Key="SettingsTitleBrush" Color="#1D3E5B" />
        <SolidColorBrush x:Key="SettingsTextBrush" Color="#35617F" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <DataTemplate x:Key="ColorPresetComboTemplate">
            <Grid Width="138">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Width="34"
                      Height="18"
                      Margin="0,0,8,0"
                      VerticalAlignment="Center">
                    <Border CornerRadius="9"
                            Background="{Binding PreviewBrush}" />
                    <Border Width="14"
                            Height="14"
                            Margin="2"
                            HorizontalAlignment="Right"
                            CornerRadius="7"
                            Background="{Binding AccentBrush}" />
                </Grid>
                <Grid x:Name="ColorPresetMarqueeViewport"
                      Grid.Column="1"
                      Height="18"
                      VerticalAlignment="Center"
                      Background="Transparent"
                      ClipToBounds="True"
                      Loaded="ColorPresetMarqueeViewport_Loaded"
                      SizeChanged="ColorPresetMarqueeViewport_SizeChanged"
                      MouseEnter="ColorPresetMarqueeViewport_MouseEnter"
                      MouseLeave="ColorPresetMarqueeViewport_MouseLeave">
                    <Canvas Height="18"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False">
                        <TextBlock x:Name="ColorPresetMarqueeText"
                                   Canvas.Left="0"
                                   Canvas.Top="1"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#1C3550"
                                   Text="{Binding Label}"
                                   Loaded="ColorPresetMarqueeText_Loaded"
                                   SizeChanged="ColorPresetMarqueeText_SizeChanged">
                            <TextBlock.RenderTransform>
                                <TranslateTransform />
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Canvas>
                </Grid>
            </Grid>
        </DataTemplate>

        <Style x:Key="FlatListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{x:Null}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="#153A5C" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#45FFFFFF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#6BFFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GlassToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="26" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#98CFDBE9" />
            <Setter Property="BorderBrush" Value="#7D9CB4CC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="SwitchTrack"
                                    CornerRadius="13"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" />
                            <Border x:Name="SwitchThumb"
                                    Width="20"
                                    Height="20"
                                    Margin="3"
                                    HorizontalAlignment="Left"
                                    CornerRadius="10"
                                    Background="#F8FFFFFF"
                                    BorderBrush="#A7C1D7EB"
                                    BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="#46000000"
                                                      BlurRadius="6"
                                                      ShadowDepth="1"
                                                      Opacity="0.35" />
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#0057D9" />
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#003F9E" />
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="SwitchThumb" Property="BorderBrush" Value="#7CA6F1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassPanelActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#0B223D" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#EAF5FFFF" />
            <Setter Property="BorderBrush" Value="#7FA5C7E6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PanelButtonBorder"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="8,6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PanelButtonBorder" Property="Background" Value="#F3FAFFFF" />
                                <Setter TargetName="PanelButtonBorder" Property="BorderBrush" Value="#6C97C2E0" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PanelButtonBorder" Property="Background" Value="#D5E9FAFF" />
                                <Setter TargetName="PanelButtonBorder" Property="BorderBrush" Value="#4D7AA7CC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorElementButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource GlassPanelActionButtonStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="MinHeight" Value="37" />
            <Setter Property="Foreground" Value="#10243C" />
            <Setter Property="Background" Value="#ECF7FBFF" />
            <Setter Property="BorderBrush" Value="#88BDD6E8" />
        </Style>

        <Style x:Key="DangerExitButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource GlassPanelActionButtonStyle}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#7B1028" />
            <Setter Property="BorderBrush" Value="#5D0B1D" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PanelButtonBorder"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="8,6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PanelButtonBorder" Property="Background" Value="#8E1632" />
                                <Setter TargetName="PanelButtonBorder" Property="BorderBrush" Value="#6A1025" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PanelButtonBorder" Property="Background" Value="#5E0D1F" />
                                <Setter TargetName="PanelButtonBorder" Property="BorderBrush" Value="#450916" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InlineNameActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource GlassPanelActionButtonStyle}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="MinWidth" Value="62" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style x:Key="GlassPresetComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#1D3E5B" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="ColorPresetComboBoxItem_PreviewMouseLeftButtonDown" />
            <EventSetter Event="PreviewMouseLeftButtonUp" Handler="ColorPresetComboBoxItem_PreviewMouseLeftButtonUp" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Margin="2"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="8"
                                BorderThickness="1"
                                BorderBrush="Transparent"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EAF5FFFF" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#8FB9D7EF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#D9EDF9FF" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#86B9CFE4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboTransparentToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassPresetComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#1D3E5B" />
            <Setter Property="Background" Value="#E8F3FBFF" />
            <Setter Property="BorderBrush" Value="#8FB9D7EF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Padding" Value="10,4,30,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    CornerRadius="10"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" />

                            <Grid Margin="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="26" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding ItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  IsHitTestVisible="False" />

                                <TextBlock Grid.Column="1"
                                           Text="⌄"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"
                                           IsHitTestVisible="False" />

                                <ToggleButton Grid.ColumnSpan="2"
                                              Focusable="False"
                                              Style="{StaticResource ComboTransparentToggleButtonStyle}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" />
                            </Grid>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Margin="0,6,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        CornerRadius="12"
                                        BorderThickness="1"
                                        BorderBrush="#86AFCDEA"
                                        Background="#ECF7FFFF">
                                    <ScrollViewer MaxHeight="240"
                                                  Margin="4"
                                                  SnapsToDevicePixels="True"
                                                  VerticalScrollBarVisibility="Hidden"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  CanContentScroll="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#4E89B8E2" />
                                <Setter TargetName="ComboBorder" Property="Background" Value="#F0F9FFFF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="Background" Value="#F2FAFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="GlassWaveStoryboard"
                    RepeatBehavior="Forever"
                    AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="GsMid"
                             Storyboard.TargetProperty="Offset"
                             From="0.35"
                             To="0.55"
                             Duration="0:0:4" />
            <DoubleAnimation Storyboard.TargetName="GsBottom"
                             Storyboard.TargetProperty="Offset"
                             From="0.92"
                             To="1.08"
                             Duration="0:0:4" />
        </Storyboard>

        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="28" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="BorderBrush" Value="#A0FFFFFF" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#80FFFFFF"
                                      BlurRadius="24"
                                      ShadowDepth="0"
                                      Opacity="0.75" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLiteVisualMode}" Value="True">
                    <Setter Property="BorderBrush" Value="#66FFFFFF" />
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#52FFFFFF"
                                              BlurRadius="12"
                                              ShadowDepth="0"
                                              Opacity="0.35" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border x:Name="GlassCard"
                Margin="6"
                Padding="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Style="{StaticResource GlassCardStyle}"
                SnapsToDevicePixels="True">
            <Border.RenderTransform>
                <ScaleTransform x:Name="UiScaleTransform"
                                ScaleX="1"
                                ScaleY="1" />
            </Border.RenderTransform>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop x:Name="GsTop" Color="#1AFFFFFF" Offset="0.0" />
                    <GradientStop x:Name="GsMid" Color="#33FFFFFF" Offset="0.4" />
                    <GradientStop x:Name="GsBottom" Color="#66FFFFFF" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid x:Name="GlassCardContent">
                <Grid x:Name="GlassTextureLayer"
                      Panel.ZIndex="0"
                      ClipToBounds="True"
                      IsHitTestVisible="False"
                      Opacity="0.88">
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop x:Name="GlassSheenTop" Offset="0" Color="#18FFFFFF" />
                                <GradientStop x:Name="GlassSheenMiddle" Offset="0.52" Color="#08FFFFFF" />
                                <GradientStop x:Name="GlassSheenBottom" Offset="1" Color="#24CFEAFF" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Rectangle Opacity="0.55">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="1,0" EndPoint="0,1">
                                <GradientStop x:Name="GlassDepthTop" Offset="0" Color="#16FFFFFF" />
                                <GradientStop x:Name="GlassDepthBottom" Offset="1" Color="#1E9BC4DF" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </Grid>

                <Grid Panel.ZIndex="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="8"
                            CornerRadius="18"
                            BorderThickness="1"
                            BorderBrush="#89FFFFFF">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop x:Name="ListTopStop" Offset="0" Color="#A7FFFFFF" />
                                <GradientStop x:Name="ListBottomStop" Offset="1" Color="#88ECF5FF" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <ListBox x:Name="DeviceListBox"
                                 ItemsSource="{Binding Devices}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 ItemContainerStyle="{StaticResource FlatListBoxItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="12,10"
                                            CornerRadius="18"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource CardTintBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsCharging}" Value="True" />
                                                            <Condition Binding="{Binding DataContext.UseCustomColors, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#FFFFF9DE" Offset="0" />
                                                                    <GradientStop Color="#FFFFE8A8" Offset="0.55" />
                                                                    <GradientStop Color="#FFFFF4C8" Offset="1" />
                                                                </LinearGradientBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter Property="BorderBrush" Value="#FFFFCF5A" />
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsChargeComplete}" Value="True" />
                                                            <Condition Binding="{Binding DataContext.UseCustomColors, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#FFEAF7FF" Offset="0" />
                                                                    <GradientStop Color="#FFC9E9FF" Offset="0.55" />
                                                                    <GradientStop Color="#FFE4F4FF" Offset="1" />
                                                                </LinearGradientBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter Property="BorderBrush" Value="#FF8FC9F0" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Grid>
                                                <Border x:Name="DeviceIconHitArea"
                                                        Width="48"
                                                        Height="48"
                                                        CornerRadius="24"
                                                        BorderThickness="1"
                                                        Cursor="Hand"
                                                        MouseLeftButtonDown="DeviceIconBorder_MouseLeftButtonDown">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource IconBackBrush}" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource IconBorderBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasCustomIconImage}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource CardTintBrush}" />
                                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid ClipToBounds="True">
                                                        <Grid.Clip>
                                                            <EllipseGeometry Center="24,24" RadiusX="23" RadiusY="23" />
                                                        </Grid.Clip>
                                                        <Image Source="{Binding CustomIconImagePath}"
                                                               Stretch="UniformToFill"
                                                               RenderOptions.BitmapScalingMode="HighQuality">
                                                            <Image.OpacityMask>
                                                                <RadialGradientBrush Center="0.5,0.5"
                                                                                     GradientOrigin="0.5,0.5"
                                                                                     RadiusX="0.62"
                                                                                     RadiusY="0.62">
                                                                    <GradientStop Color="#FFFFFFFF" Offset="0.62" />
                                                                    <GradientStop Color="#C8FFFFFF" Offset="0.82" />
                                                                    <GradientStop Color="#00FFFFFF" Offset="1" />
                                                                </RadialGradientBrush>
                                                            </Image.OpacityMask>
                                                            <Image.Style>
                                                                <Style TargetType="Image">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasCustomIconImage}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Image.Style>
                                                        </Image>

                                                        <TextBlock HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="20"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   Foreground="#20537A"
                                                                   Text="{Binding IconKey, Converter={StaticResource IconGlyphConverter}}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasCustomIconImage}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>

                                                <Popup PlacementTarget="{Binding ElementName=DeviceIconHitArea}"
                                                       Placement="Bottom"
                                                       AllowsTransparency="True"
                                                       PopupAnimation="Fade"
                                                       StaysOpen="True"
                                                       IsOpen="{Binding IsIconEditing, Mode=TwoWay}">
                                                    <Popup.DataContext>
                                                        <Binding ElementName="DeviceIconHitArea" Path="DataContext" />
                                                    </Popup.DataContext>
                                                    <Border Margin="0,8,0,0"
                                                            Padding="9"
                                                            MinWidth="142"
                                                            CornerRadius="12"
                                                            BorderThickness="1"
                                                            Background="#F3F8FFFF"
                                                            BorderBrush="#8AB0CEE6">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="#56000000"
                                                                              BlurRadius="14"
                                                                              ShadowDepth="2"
                                                                              Opacity="0.26" />
                                                        </Border.Effect>
                                                        <StackPanel>
                                                            <Button Content="{Binding DataContext.TextIconChange, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    Style="{StaticResource InlineNameActionButtonStyle}"
                                                                    Click="IconPickInlineButton_Click" />
                                                            <Button Content="{Binding DataContext.TextRestoreDefault, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    Margin="0,6,0,0"
                                                                    Style="{StaticResource InlineNameActionButtonStyle}"
                                                                    Click="IconResetInlineButton_Click" />
                                                            <Button Content="{Binding DataContext.TextInlineCancel, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    Margin="0,6,0,0"
                                                                    Style="{StaticResource InlineNameActionButtonStyle}"
                                                                    Click="IconCancelInlineButton_Click" />
                                                        </StackPanel>
                                                    </Border>
                                                </Popup>
                                            </Grid>

                                            <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                                                <TextBlock x:Name="DisplayNameTextBlock"
                                                           Text="{Binding DisplayName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           FontSize="17"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           Cursor="Hand"
                                                           MouseLeftButtonDown="DisplayNameTextBlock_MouseLeftButtonDown">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <StackPanel x:Name="RenameEditorPanel"
                                                            Margin="0,0,0,2"
                                                            Visibility="{Binding IsRenaming, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBox x:Name="NameEditorTextBox"
                                                             Text="{Binding EditableName, UpdateSourceTrigger=PropertyChanged}"
                                                             FontSize="13"
                                                             Padding="6,3"
                                                             Margin="0,0,0,5"
                                                             KeyDown="NameEditorTextBox_KeyDown"
                                                             IsVisibleChanged="NameEditorTextBox_IsVisibleChanged" />

                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="{Binding DataContext.TextInlineSave, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                Style="{StaticResource InlineNameActionButtonStyle}"
                                                                Click="NameSaveButton_Click" />
                                                        <Button Content="{Binding DataContext.TextInlineCancel, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                Style="{StaticResource InlineNameActionButtonStyle}"
                                                                Click="NameCancelButton_Click" />
                                                        <Button Content="{Binding DataContext.TextRestoreDefault, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                Click="NameResetButton_Click">
                                                            <Button.Style>
                                                                <Style TargetType="Button"
                                                                       BasedOn="{StaticResource InlineNameActionButtonStyle}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasCustomName}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </StackPanel>
                                                </StackPanel>

                                                <TextBlock Text="{Binding Address}"
                                                           Margin="0,2,0,0"
                                                           FontSize="14"
                                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Top"
                                                        HorizontalAlignment="Right">
                                                <TextBlock FontSize="28"
                                                           FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource BatteryTextBrush}" />
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource BatteryPercentTextConverter}">
                                                            <Binding Path="BatteryPercent" />
                                                            <Binding Path="IsStale" />
                                                            <Binding Path="IsConnected" />
                                                            <Binding Path="IsBatteryConnecting" />
                                                            <Binding Path="IsCharging" />
                                                            <Binding Path="DataContext.Language" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <TextBlock Text="&#xE945;"
                                                           Margin="6,2,0,0"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding IsCharging, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#B7791F" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsChargeComplete}" Value="True">
                                                                    <Setter Property="Foreground" Value="#1D5F8B" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>

                                            <Grid Grid.Row="1"
                                                  Grid.Column="1"
                                                  Grid.ColumnSpan="2"
                                                  Margin="0,10,0,0"
                                                  Height="12">
                                                <Border x:Name="BatteryTrack"
                                                        Height="12"
                                                        CornerRadius="6"
                                                        Background="{DynamicResource TrackBrush}" />
                                                <Border Height="12"
                                                        HorizontalAlignment="Left"
                                                        CornerRadius="6"
                                                        ClipToBounds="True"
                                                        Background="{Binding BatteryPercent, Converter={StaticResource BatteryFillBrushConverter}}">
                                                    <Border.Width>
                                                        <MultiBinding Converter="{StaticResource BatteryWidthConverter}">
                                                            <Binding Path="BatteryPercent" />
                                                            <Binding ElementName="BatteryTrack" Path="ActualWidth" />
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <Border x:Name="StatusPanelBorder"
                            Grid.Row="1"
                            Margin="0,14,0,0"
                            Padding="12,9"
                            CornerRadius="18"
                            BorderThickness="1"
                            BorderBrush="#8EFFFFFF">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusPanelCollapsed}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop x:Name="FooterTopStop" Offset="0" Color="#C8FFFFFF" />
                                <GradientStop x:Name="FooterBottomStop" Offset="1" Color="#ADECF7FF" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Vertical">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Border Width="24"
                                            Height="24"
                                            Margin="0,0,8,0"
                                            CornerRadius="12"
                                            BorderThickness="1"
                                            Background="{DynamicResource ActionButtonBackBrush}"
                                            BorderBrush="{DynamicResource ActionButtonBorderBrush}">
                                        <Button Style="{StaticResource RoundActionButtonStyle}"
                                                Cursor="Hand"
                                                Click="StatusPanelToggleButton_Click"
                                                ToolTip="{Binding TextStatusPanelCollapseTooltip}">
                                            <TextBlock Text="−"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center" />
                                        </Button>
                                    </Border>

                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="{Binding StatusText}" />
                                </StackPanel>

                                <TextBlock Margin="0,2,0,0"
                                           FontSize="13"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="{Binding DiagnosticsText}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusPanelCollapsed}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBlock Margin="0,1,0,0"
                                           FontSize="13"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="{Binding PerformanceText}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusPanelCollapsed}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Border Width="34"
                                        Height="34"
                                        Margin="0,0,8,0"
                                        CornerRadius="17"
                                        BorderThickness="1"
                                        Background="{DynamicResource ActionButtonBackBrush}"
                                        BorderBrush="{DynamicResource ActionButtonBorderBrush}">
                                    <Button x:Name="SettingsButton"
                                            Style="{StaticResource RoundActionButtonStyle}"
                                            Click="SettingsButton_Click"
                                            ToolTip="{Binding TextSettingsTooltip}">
                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" />
                                    </Button>
                                </Border>

                                <Border Width="34"
                                        Height="34"
                                        CornerRadius="17"
                                        BorderThickness="1"
                                        Background="{DynamicResource ActionButtonBackBrush}"
                                        BorderBrush="{DynamicResource ActionButtonBorderBrush}">
                                    <Button x:Name="MainCloseButton"
                                            Style="{StaticResource RoundActionButtonStyle}"
                                            Click="CloseButton_Click"
                                            ToolTip="{Binding TextCloseTooltip}">
                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;" />
                                    </Button>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Margin="8,14,0,10"
                            Width="28"
                            Height="28"
                            CornerRadius="14"
                            BorderThickness="1"
                            Background="{DynamicResource ActionButtonBackBrush}"
                            BorderBrush="{DynamicResource ActionButtonBorderBrush}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusPanelCollapsed}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button x:Name="StatusPanelToggleButton"
                                Style="{StaticResource RoundActionButtonStyle}"
                                ToolTip="{Binding TextStatusPanelToggleTooltip}"
                                Click="StatusPanelToggleButton_Click">
                            <TextBlock Text="+"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Button>
                    </Border>

                </Grid>
            </Grid>
        </Border>

        <Thumb x:Name="ResizeGripThumb"
               Width="16"
               Height="16"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Margin="0,0,4,4"
               Panel.ZIndex="50"
               DragDelta="ResizeGripThumb_DragDelta"
               ToolTip="Resize">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Grid Width="16" Height="16" Background="Transparent">
                        <Canvas Width="10" Height="10"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom">
                            <Ellipse Width="2.1" Height="2.1" Fill="#EEF6FCFF" Canvas.Left="0.8" Canvas.Top="7.2" />
                            <Ellipse Width="2.1" Height="2.1" Fill="#EEF6FCFF" Canvas.Left="4.2" Canvas.Top="7.2" />
                            <Ellipse Width="2.1" Height="2.1" Fill="#EEF6FCFF" Canvas.Left="7.6" Canvas.Top="7.2" />
                            <Ellipse Width="2.1" Height="2.1" Fill="#EEF6FCFF" Canvas.Left="4.2" Canvas.Top="3.8" />
                            <Ellipse Width="2.1" Height="2.1" Fill="#EEF6FCFF" Canvas.Left="7.6" Canvas.Top="3.8" />
                            <Ellipse Width="2.1" Height="2.1" Fill="#EEF6FCFF" Canvas.Left="7.6" Canvas.Top="0.4" />
                        </Canvas>
                    </Grid>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>

        <Popup x:Name="SettingsPopup"
               AllowsTransparency="True"
               PlacementTarget="{Binding ElementName=StatusPanelBorder}"
               Placement="Bottom"
               HorizontalOffset="8"
               VerticalOffset="8"
               StaysOpen="True">
            <Border x:Name="SettingsPopupChrome"
                    Width="340"
                    Padding="12"
                    CornerRadius="18"
                    BorderThickness="1"
                    BorderBrush="#9DD0E1F4"
                    Background="#F2EAF6FF"
                    Cursor="Arrow"
                    Focusable="False"
                    FocusVisualStyle="{x:Null}">
                <Border.Effect>
                    <DropShadowEffect Color="#70000000"
                                      BlurRadius="16"
                                      ShadowDepth="4"
                                      Opacity="0.25" />
                </Border.Effect>
                <ScrollViewer MaxHeight="600"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False"
                              Cursor="Arrow">
                    <StackPanel Cursor="Arrow">
                    <Grid MinHeight="24"
                          Margin="0,0,0,8"
                          Background="Transparent"
                          Cursor="Arrow">
                        <TextBlock x:Name="SettingsTitleTextBlock"
                                    VerticalAlignment="Center"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource SettingsTitleBrush}"
                                    IsHitTestVisible="False"
                                    Text="{Binding TextSettingsTitle}" />
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="AutostartLabelTextBlock"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SettingsTextBrush}"
                                   Text="{Binding TextAutostart}" />
                        <ToggleButton x:Name="AutostartToggle"
                                      Grid.Column="1"
                                      Style="{StaticResource GlassToggleSwitchStyle}"
                                      IsChecked="{Binding AutostartEnabled, Mode=OneWay}"
                                      Checked="AutostartToggle_Checked"
                                      Unchecked="AutostartToggle_Unchecked" />
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CloseToTrayLabelTextBlock"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SettingsTextBrush}"
                                   Text="{Binding TextCloseToTray}" />
                        <ToggleButton x:Name="CloseToTrayToggle"
                                      Grid.Column="1"
                                      Style="{StaticResource GlassToggleSwitchStyle}"
                                      IsChecked="{Binding CloseToTrayEnabled, Mode=OneWay}"
                                      Checked="CloseToTrayToggle_Checked"
                                      Unchecked="CloseToTrayToggle_Unchecked" />
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="GuidedProbeLabelTextBlock"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SettingsTextBrush}"
                                   Text="{Binding TextGuidedProbe}" />
                        <ToggleButton x:Name="GuidedProbeToggle"
                                      Grid.Column="1"
                                      Style="{StaticResource GlassToggleSwitchStyle}"
                                      IsChecked="{Binding GuidedProbeEnabled, Mode=OneWay}"
                                      Checked="GuidedProbeToggle_Checked"
                                      Unchecked="GuidedProbeToggle_Unchecked" />
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="AggressivePolicyLabelTextBlock"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SettingsTextBrush}"
                                   Text="{Binding TextAggressivePolicy}" />
                        <ToggleButton x:Name="AggressivePolicyToggle"
                                      Grid.Column="1"
                                      Style="{StaticResource GlassToggleSwitchStyle}"
                                      IsChecked="{Binding IsAggressiveThirdPartyPolicy, Mode=OneWay}"
                                      Checked="AggressivePolicyToggle_Checked"
                                      Unchecked="AggressivePolicyToggle_Unchecked" />
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="UiScaleLabelTextBlock"
                                   Grid.Row="0"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SettingsTextBrush}"
                                   Text="{Binding TextUiScale}" />
                        <TextBlock Grid.Row="0"
                                   Grid.Column="1"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource SettingsTitleBrush}"
                                   Text="{Binding UiScaleStep, StringFormat={}{0:+#;-#;0}}" />
                        <Slider x:Name="UiScaleSlider"
                                Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Margin="0,6,0,0"
                                Minimum="-5"
                                Maximum="0"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                SmallChange="1"
                                LargeChange="1"
                                Value="{Binding UiScaleStep, Mode=OneWay}"
                                ValueChanged="UiScaleSlider_ValueChanged" />
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ColorPresetLabelTextBlock"
                                   Grid.Column="0"
                                   Margin="0,0,10,6"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SettingsTextBrush}"
                                   Text="{Binding TextColorPreset}" />
                        <ComboBox x:Name="ColorPresetComboBox"
                                  Grid.Column="1"
                                  Width="166"
                                  Height="30"
                                  Style="{StaticResource GlassPresetComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource GlassPresetComboBoxItemStyle}"
                                  ItemTemplate="{StaticResource ColorPresetComboTemplate}"
                                  PreviewMouseLeftButtonDown="ColorPresetComboBox_PreviewMouseLeftButtonDown"
                                  MouseEnter="ColorPresetComboBox_MouseEnter"
                                  MouseLeave="ColorPresetComboBox_MouseLeave"
                                  SelectionChanged="ColorPresetComboBox_SelectionChanged" />
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Button x:Name="ColorCustomizeButton"
                                Style="{StaticResource GlassPanelActionButtonStyle}"
                                Click="ColorCustomizeButton_Click"
                                HorizontalContentAlignment="Stretch">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid Width="30"
                                      Height="18"
                                      Margin="0,0,9,0"
                                      VerticalAlignment="Center">
                                    <Border CornerRadius="9">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FFFFF5EA" Offset="0" />
                                                <GradientStop Color="#FFD7F5E8" Offset="0.45" />
                                                <GradientStop Color="#FFDAD8FF" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Border Width="10"
                                            Height="10"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            CornerRadius="5"
                                            Background="#FF2F6BFF" />
                                </Grid>
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Text="색상 커스텀" />
                                <TextBlock Grid.Column="2"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="15"
                                           Text="›" />
                            </Grid>
                        </Button>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Margin="0,0,0,6"
                                   Foreground="{StaticResource SettingsTextBrush}"
                                   Text="사용자 폰트" />
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="LoadCustomFontButton"
                                    Grid.Column="0"
                                    Margin="0,0,6,0"
                                    Style="{StaticResource GlassPanelActionButtonStyle}"
                                    Click="LoadCustomFontButton_Click"
                                    Content="불러오기" />
                            <Button x:Name="ResetCustomFontButton"
                                    Grid.Column="1"
                                    Margin="6,0,0,0"
                                    Style="{StaticResource GlassPanelActionButtonStyle}"
                                    Click="ResetCustomFontButton_Click"
                                    Content="기본값" />
                        </Grid>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LanguageLabelTextBlock"
                                   Grid.Column="0"
                                   Margin="0,0,10,6"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SettingsTextBrush}"
                                   Text="Language" />
                        <ComboBox x:Name="LanguageComboBox"
                                  Grid.Column="1"
                                  Width="166"
                                  Height="30"
                                  Style="{StaticResource GlassPresetComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource GlassPresetComboBoxItemStyle}"
                                  SelectionChanged="LanguageComboBox_SelectionChanged"
                                  DisplayMemberPath="Label" />
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,6,6"
                                Style="{StaticResource GlassPanelActionButtonStyle}"
                                Click="ManualRefreshButton_Click"
                                Content="{Binding TextRefreshNow}" />
                        <Button Grid.Row="0"
                                Grid.Column="1"
                                Margin="6,0,0,6"
                                Style="{StaticResource GlassPanelActionButtonStyle}"
                                Click="DeveloperContactButton_Click"
                                Content="{Binding TextDeveloperContact}" />

                        <Button Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,0,6,0"
                                x:Name="UpdateButton"
                                Style="{StaticResource GlassPanelActionButtonStyle}"
                                Click="UpdateButton_Click"
                                Content="{Binding TextUpdate}" />

                        <Button Grid.Row="1"
                                Grid.Column="1"
                                Margin="6,0,0,0"
                                Style="{StaticResource GlassPanelActionButtonStyle}"
                                Click="SupportButton_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Image Source="pack://application:,,,/Assets/kofi_symbol.png"
                                       Width="16"
                                       Height="16"
                                       Margin="0,0,6,0"
                                       Stretch="Uniform" />
                                <TextBlock VerticalAlignment="Center"
                                           Text="{Binding TextSupport}" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Row="2"
                                Grid.ColumnSpan="2"
                                Margin="0,6,0,0"
                                Style="{StaticResource DangerExitButtonStyle}"
                                Click="ExitButton_Click"
                                Content="{Binding TextExit}" />

                        <StackPanel x:Name="UpdateProgressPanel"
                                    Grid.Row="3"
                                    Grid.ColumnSpan="2"
                                    Margin="0,8,0,0"
                                    Visibility="Collapsed">
                            <ProgressBar x:Name="UpdateProgressBar"
                                         Height="12"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="0" />
                            <TextBlock x:Name="UpdateProgressTextBlock"
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource SettingsTextBrush}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="VersionTextBlock"
                               HorizontalAlignment="Right"
                               FontSize="12"
                               Foreground="{StaticResource SettingsTextBrush}"
                               Text="버전 1.0.3" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Popup>

        <Popup x:Name="ColorCustomPopup"
               AllowsTransparency="True"
               PlacementTarget="{Binding ElementName=ColorCustomizeButton}"
               Placement="Right"
               HorizontalOffset="10"
               VerticalOffset="-8"
               StaysOpen="True">
            <Border x:Name="ColorPopupChrome"
                    Width="360"
                    Padding="12"
                    CornerRadius="18"
                    BorderThickness="1"
                    BorderBrush="#A6D2E7F4"
                    Background="#F4F7FBFF"
                    PreviewMouseLeftButtonDown="PopupChrome_MouseLeftButtonDown"
                    MouseLeftButtonDown="PopupChrome_MouseLeftButtonDown"
                    MouseMove="PopupChrome_MouseMove"
                    MouseLeftButtonUp="PopupChrome_MouseLeftButtonUp"
                    LostMouseCapture="PopupChrome_LostMouseCapture">
                <Border.Effect>
                    <DropShadowEffect Color="#68000000"
                                      BlurRadius="18"
                                      ShadowDepth="4"
                                      Opacity="0.26" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel IsHitTestVisible="False">
                            <TextBlock FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource SettingsTitleBrush}"
                                       Text="색상 커스텀" />
                            <TextBlock x:Name="SelectedColorNameText"
                                       Margin="0,2,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource SettingsTextBrush}"
                                       Text="전체 글자" />
                        </StackPanel>
                        <Thumb x:Name="ColorPopupDragThumb"
                               Grid.Column="0"
                               Focusable="False"
                               Cursor="Arrow"
                               DragDelta="ColorPopupDragThumb_DragDelta">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Border Background="Transparent" />
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                        <Button Grid.Column="1"
                                Width="28"
                                Height="28"
                                Style="{StaticResource RoundActionButtonStyle}"
                                Click="ColorCustomCloseButton_Click">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE711;" />
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="142" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,10,0">
                            <Button x:Name="PrimaryTextColorButton"
                                    Tag="PrimaryText"
                                    Style="{StaticResource ColorElementButtonStyle}"
                                    Click="ColorElementButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="PrimaryTextSwatch" Width="20" Height="20" HorizontalAlignment="Left" CornerRadius="10" Background="{DynamicResource PrimaryTextBrush}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="전체 글자" />
                                </Grid>
                            </Button>
                            <Button x:Name="SecondaryTextColorButton"
                                    Tag="SecondaryText"
                                    Style="{StaticResource ColorElementButtonStyle}"
                                    Click="ColorElementButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="SecondaryTextSwatch" Width="20" Height="20" HorizontalAlignment="Left" CornerRadius="10" Background="{DynamicResource SecondaryTextBrush}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="보조 글자" />
                                </Grid>
                            </Button>
                            <Button x:Name="BatteryTextColorButton"
                                    Tag="BatteryText"
                                    Style="{StaticResource ColorElementButtonStyle}"
                                    Click="ColorElementButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="BatteryTextSwatch" Width="20" Height="20" HorizontalAlignment="Left" CornerRadius="10" Background="{DynamicResource BatteryTextBrush}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="배터리 숫자" />
                                </Grid>
                            </Button>
                            <Button x:Name="CardTintColorButton"
                                    Tag="CardTint"
                                    Style="{StaticResource ColorElementButtonStyle}"
                                    Click="ColorElementButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="CardTintSwatch" Width="20" Height="20" HorizontalAlignment="Left" CornerRadius="10" Background="{DynamicResource CardTintBrush}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="기기 칸" />
                                </Grid>
                            </Button>
                            <Button x:Name="CardBorderColorButton"
                                    Tag="CardBorder"
                                    Style="{StaticResource ColorElementButtonStyle}"
                                    Click="ColorElementButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="CardBorderSwatch" Width="20" Height="20" HorizontalAlignment="Left" CornerRadius="10" Background="{DynamicResource CardBorderBrush}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="기기 테두리" />
                                </Grid>
                            </Button>
                            <Button x:Name="TrackColorButton"
                                    Tag="Track"
                                    Style="{StaticResource ColorElementButtonStyle}"
                                    Click="ColorElementButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="TrackSwatch" Width="20" Height="20" HorizontalAlignment="Left" CornerRadius="10" Background="{DynamicResource TrackBrush}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="막대 배경" />
                                </Grid>
                            </Button>
                            <Button x:Name="PanelColorButton"
                                    Tag="Panel"
                                    Style="{StaticResource ColorElementButtonStyle}"
                                    Click="ColorElementButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="PanelSwatch" Width="20" Height="20" HorizontalAlignment="Left" CornerRadius="10" Background="{DynamicResource ActionButtonBackBrush}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="하단 패널" />
                                </Grid>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <Border x:Name="PaletteSurface"
                                    Height="172"
                                    CornerRadius="16"
                                    ClipToBounds="True"
                                    MouseLeftButtonDown="PaletteSurface_MouseLeftButtonDown"
                                    MouseMove="PaletteSurface_MouseMove"
                                    MouseLeftButtonUp="PaletteSurface_MouseLeftButtonUp"
                                    MouseLeave="PaletteSurface_MouseLeave">
                                <Grid Background="Transparent">
                                    <Rectangle>
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FFFF5656" Offset="0.00" />
                                                <GradientStop Color="#FFFFD84D" Offset="0.16" />
                                                <GradientStop Color="#FF6EE7A7" Offset="0.32" />
                                                <GradientStop Color="#FF44D7E8" Offset="0.50" />
                                                <GradientStop Color="#FF6B8CFF" Offset="0.68" />
                                                <GradientStop Color="#FFC977F2" Offset="0.84" />
                                                <GradientStop Color="#FFFF6BAA" Offset="1.00" />
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <Rectangle>
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#DDFFFFFF" Offset="0" />
                                                <GradientStop Color="#00FFFFFF" Offset="0.45" />
                                                <GradientStop Color="#99000000" Offset="1" />
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <Ellipse x:Name="PaletteCursor"
                                             Width="16"
                                             Height="16"
                                             Stroke="#F8FFFFFF"
                                             StrokeThickness="2"
                                             Fill="#33000000"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Top"
                                             Margin="0" />
                                </Grid>
                            </Border>

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="SelectedColorPreviewBorder"
                                        Width="38"
                                        Height="30"
                                        CornerRadius="10"
                                        BorderThickness="1"
                                        BorderBrush="#88A7BED2"
                                        Background="{DynamicResource PrimaryTextBrush}" />
                                <TextBlock x:Name="SelectedColorHexText"
                                           Grid.Column="1"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SettingsTitleBrush}"
                                           Text="#10243C" />
                            </Grid>

                            <Button Margin="0,10,0,0"
                                    Style="{StaticResource GlassPanelActionButtonStyle}"
                                    Click="ResetCustomColorsButton_Click"
                                    Content="색상 초기화" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Grid.Row="2"
                               Margin="0,10,0,0"
                               FontSize="11"
                               Foreground="{StaticResource SettingsTextBrush}"
                               Text="마우스를 누른 채 움직이면 바로 반영됩니다." />
                </Grid>
            </Border>
        </Popup>
    </Grid>
</Window>
